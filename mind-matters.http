# Mind-Matters API

###
# group: User Profile & Assessment
# @name Get Profile
GET {{base_url}}/profile
x-user-id: user_123

###
# group: User Profile & Assessment
# @name Update Profile
POST {{base_url}}/profile
x-user-id: user_123
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Doe",
  "email": "john.doe@example.com"
}

###
# group: Activity Tracking / Mood
# @name Get Moods
GET {{base_url}}/mood
x-user-id: user_123

###
# group: Activity Tracking / Mood
# @name Log Mood
POST {{base_url}}/mood
x-user-id: user_123
Content-Type: application/json

{
  "value": 4,
  "note": "Feeling good today"
}

###
# group: Activity Tracking / Journaling
# @name Get Journals
GET {{base_url}}/journal
x-user-id: user_123

###
# group: Activity Tracking / Journaling
# @name Create Journal Entry
POST {{base_url}}/journal
x-user-id: user_123
Content-Type: application/json

{
  "title": "Morning Reflection",
  "content": "Had a peaceful morning walk."
}

###
# group: Stress Management
# @name Get Stress Kit
GET {{base_url}}/stress/kit
x-user-id: user_123

###
# group: Stress Management
# @name Update Stress Kit
PUT {{base_url}}/stress/kit
x-user-id: user_123
Content-Type: application/json

{
  "triggers": [
    "work stress",
    "lack of sleep"
  ],
  "helpfulActions": [
    "deep breathing",
    "walk"
  ],
  "people": [
    "best friend"
  ]
}

###
# group: Chat & AI
# @name Chat with AI
POST {{base_url}}/chat
x-user-id: user_123
Content-Type: application/json

{
  "issueTitle": "Feeling anxious",
  "issueTags": [
    "anxiety",
    "stress"
  ],
  "messages": [
    {
      "sender": "user",
      "text": "I'm feeling a bit overwhelmed today."
    }
  ]
}

###
# group: Chat & AI
# @name Get Chat History
GET {{base_url}}/chat/history/anxiety-issue
x-user-id: user_123

###
# group: Payments
# @name Create Checkout Session
POST {{base_url}}/create-checkout-session
x-user-id: user_123
Content-Type: application/json

{
  "mode": "payment",
  "currency": "usd",
  "price_data": {
    "name": "Premium Support",
    "unit_amount": 2900
  }
}